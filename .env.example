VITE_SUPABASE_PROJECT_ID=your-project-id
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-or-publishable-key
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# AdMob (apenas para o app Android). Sem estes valores, o app usa os
# ad units DE TESTE do Google. O App ID fica em
# android/app/src/main/res/values/strings.xml (admob_app_id).
VITE_ADMOB_BANNER_ID=
VITE_ADMOB_INTERSTITIAL_ID=
# Liga os anúncios (independe do paywall Pro). Sem "true", o SDK de Ads NEM
# inicializa — evita servir test ads em produção. Ligue só com os ad-units
# e o App ID REAIS configurados.
VITE_ADS_ENABLED=

# Telemetria (PostHog). Sem a chave, nenhum SDK é carregado e nenhum
# dado sai do aparelho. Host padrão: https://us.i.posthog.com
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=

# Vídeos de teoria (Remotion). URL pública (sem barra final) do bucket onde
# os MP4 estão hospedados — ex.: Supabase Storage público. Espera o layout
# <base>/<courseId>/<lessonId>.mp4. Vazio = recurso DESLIGADO (sem card de
# vídeo). Veja docs/videos-teoria.md.
VITE_THEORY_VIDEO_BASE=
